rules_version = '2';

// ============================================================
// Firebase Storage Security Rules
// ⚠️ বর্তমানে এই অ্যাপ ছবি আপলোডের জন্য Cloudinary ব্যবহার করছে (Firebase
// Storage-এর জন্য Blaze/billing প্ল্যান বাধ্যতামূলক হওয়ায়), তাই এই ফাইলটি
// এখন ব্যবহার হচ্ছে না। ভবিষ্যতে Blaze-এ আপগ্রেড করে Firebase Storage-এ
// ফিরে যেতে চাইলে এই rules Firebase Console → Storage → Rules ট্যাবে
// পেস্ট করে Publish করুন এবং js/*.js ফাইলে আবার storage.ref() কোড ব্যবহার
// করুন।
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {

    // প্রোফাইল ছবি: শুধুমাত্র মালিক আপলোড/পরিবর্তন করতে পারবে, যেকোনো লগইনকৃত ইউজার দেখতে পারবে
    match /avatars/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 4 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // চ্যাট ইমেজ: শুধুমাত্র সংশ্লিষ্ট চ্যাটের participant রা আপলোড/দেখতে পারবে
    match /chatImages/{chatId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.uid in chatId.split('_');
      allow write: if request.auth != null
        && request.auth.uid in chatId.split('_')
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
