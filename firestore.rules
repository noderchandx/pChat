rules_version = '2';

// ============================================================
// Firestore Security Rules
// Firebase Console → Firestore Database → Rules ট্যাবে এই কোড পেস্ট করুন
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isParticipant(chatId) {
      return isSignedIn() &&
        request.auth.uid in chatId.split('_');
    }

    // ---------------- users/{uid} ----------------
    match /users/{uid} {
      // যেকোনো লগইনকৃত ইউজার প্রোফাইল পড়তে পারবে (সার্চ, চ্যাটলিস্টের জন্য দরকার)
      allow read: if isSignedIn();
      // নিজের প্রোফাইল শুধুমাত্র সাইনআপের সময় create, এবং পরে নিজে update করতে পারবে
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['name','mobile','photoURL','status','blocked'])
        && request.resource.data.name is string
        && request.resource.data.mobile is string;
      allow update: if isOwner(uid)
        // মোবাইল নম্বর পরিবর্তনযোগ্য নয়
        && request.resource.data.mobile == resource.data.mobile;
      allow delete: if false;
    }

    // ---------------- mobileIndex/{mobile} ----------------
    // মোবাইল নম্বরের uniqueness নিশ্চিত করতে ব্যবহৃত হয়
    match /mobileIndex/{mobile} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------------- chats/{chatId} ----------------
    match /chats/{chatId} {
      allow read: if isParticipant(chatId);
      allow create: if isParticipant(chatId)
        && request.auth.uid in request.resource.data.participants;
      // শুধু participant রা lastMessage/unread আপডেট করতে পারবে
      allow update: if isParticipant(chatId);
      allow delete: if false;

      // ---------------- chats/{chatId}/messages/{messageId} ----------------
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);

        allow create: if isParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;

        // মেসেজ আপডেট: শুধু নিজের মেসেজ ডিলিট (soft-delete) করা যাবে,
        // অথবা যেকোনো participant রিয়্যাকশন যোগ করতে পারবে।
        allow update: if isParticipant(chatId) && (
          // Reaction আপডেট: শুধুমাত্র নিজের uid-কী পরিবর্তন
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
          ||
          // Seen/delivered status আপডেট (প্রাপক করে)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
          ||
          // নিজের মেসেজ soft-delete
          (resource.data.senderId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted','text','imageURL']))
        );

        allow delete: if false; // সবসময় soft-delete (deleted:true) ব্যবহার করুন
      }
    }
  }
}
